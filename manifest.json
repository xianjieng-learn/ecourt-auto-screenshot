{
  "manifest_version": 3,
  "name": "eCourt Auto Screenshot",
  "version": "1.1",
  "description": "Auto screenshot popup di eCourt (username/password)",
  "key": "",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://ecourt.mahkamahagung.go.id/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://ecourt.mahkamahagung.go.id/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "eCourt Auto Screenshot"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
